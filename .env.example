# Copy to .env for local development. Values shown are the defaults.

# Stage: local | dev | prod
STAGE=local

# Local HTTP server
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# Web app URL (used for CORS and e-mail links)
APP_URL=http://localhost:3000

# --- Database ---
# Local dev: Postgres connection string (driver: postgres.js).
# Run a local Postgres (e.g. Docker) and apply migrations with `npm run db:migrate`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fluxy
DB_NAME=fluxy
# Deployed stages read the Neon connection string from SSM (leave empty locally):
# DATABASE_URL_PARAM=/fluxy/dev/database-url

# --- Auth / tokens ---
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
VERIFY_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_HOURS=1
# Local dev secret (deployed stages read it from SSM via JWT_SECRET_PARAM).
JWT_SECRET=dev-insecure-jwt-secret-change-me
# JWT_SECRET_PARAM=/fluxy/dev/jwt-secret

# --- E-mail (Resend) ---
EMAIL_FROM=Fluxy <onboarding@resend.dev>
# Without a key, e-mails are logged to the console instead of being sent.
# RESEND_API_KEY=
# RESEND_API_KEY_PARAM=/fluxy/dev/resend-api-key
